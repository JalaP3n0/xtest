{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/luxury-preview/layout,_N_T_/luxury-preview/page,_N_T_/luxury-preview"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/luxury-preview/__PAGE__",
    "/luxury-preview",
    "/_index",
    "/_head"
  ]
}